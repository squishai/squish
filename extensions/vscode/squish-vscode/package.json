{
  "name": "squish-vscode",
  "displayName": "Squish Agent",
  "description": "Squish Agent — agentic AI pair-programmer powered by your local Squish model. Full chat, monitoring dashboard, agentic file editing, CodeLens, and inline completions.",
  "version": "0.2.0",
  "publisher": "squishai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/squishai/squish"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "media/icon.png",
  "categories": ["AI", "Chat", "Other"],
  "keywords": ["ai", "agent", "llm", "local", "mlx", "apple-silicon", "chat", "copilot", "squish"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "squish.openChat",
        "title": "Squish Agent: Open Chat",
        "icon": "$(hubot)"
      },
      {
        "command": "squish.newChat",
        "title": "Squish Agent: New Conversation",
        "icon": "$(add)"
      },
      {
        "command": "squish.startServer",
        "title": "Squish Agent: Start Server"
      },
      {
        "command": "squish.stopServer",
        "title": "Squish Agent: Stop Server"
      },
      {
        "command": "squish.selectModel",
        "title": "Squish Agent: Select Model"
      },
      {
        "command": "squish.clearHistory",
        "title": "Squish Agent: Clear Conversation"
      },
      {
        "command": "squish.explainSelection",
        "title": "Squish Agent: Explain Selection"
      },
      {
        "command": "squish.fixDiagnostic",
        "title": "Squish Agent: Fix Error"
      },
      {
        "command": "squish.refactorSelection",
        "title": "Squish Agent: Refactor Selection"
      },
      {
        "command": "squish.documentFunction",
        "title": "Squish Agent: Add Documentation"
      },
      {
        "command": "squish.generateTests",
        "title": "Squish Agent: Generate Tests"
      },
      {
        "command": "squish.openMonitor",
        "title": "Squish Agent: Open Monitoring Dashboard",
        "icon": "$(pulse)"
      },
      {
        "command": "squish.openInPanel",
        "title": "Squish Agent: Open Chat in Editor Panel"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "squish",
          "title": "Squish Agent",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "squish": [
        {
          "type": "webview",
          "id": "squish.chatView",
          "name": "Chat"
        },
        {
          "type": "webview",
          "id": "squish.monitorView",
          "name": "Monitor"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "squish.explainSelection",
          "when": "editorHasSelection",
          "group": "squish@1"
        },
        {
          "command": "squish.refactorSelection",
          "when": "editorHasSelection",
          "group": "squish@2"
        },
        {
          "command": "squish.documentFunction",
          "when": "editorHasSelection",
          "group": "squish@3"
        },
        {
          "command": "squish.generateTests",
          "when": "editorHasSelection",
          "group": "squish@4"
        },
        {
          "command": "squish.fixDiagnostic",
          "when": "editorHasSelection",
          "group": "squish@5"
        }
      ],
      "view/title": [
        {
          "command": "squish.newChat",
          "when": "view == squish.chatView",
          "group": "navigation"
        },
        {
          "command": "squish.openMonitor",
          "when": "view == squish.chatView",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "squish.openChat",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s"
      },
      {
        "command": "squish.explainSelection",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      },
      {
        "command": "squish.fixDiagnostic",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "editorFocus"
      }
    ],
    "configuration": {
      "title": "Squish Agent",
      "properties": {
        "squish.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Hostname or IP of the Squish server."
        },
        "squish.port": {
          "type": "number",
          "default": 11435,
          "description": "Port of the Squish server."
        },
        "squish.apiKey": {
          "type": "string",
          "default": "squish",
          "description": "Bearer token for the Squish server API."
        },
        "squish.model": {
          "type": "string",
          "default": "7b",
          "description": "Model shorthand or path to start (e.g. 7b, 14b, 1.5b)."
        },
        "squish.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start the Squish server when VS Code opens."
        },
        "squish.maxTokens": {
          "type": "number",
          "default": 4096,
          "description": "Maximum tokens per response."
        },
        "squish.temperature": {
          "type": "number",
          "default": 0.7,
          "description": "Sampling temperature (0 = deterministic, 1 = creative)."
        },
        "squish.systemPrompt": {
          "type": "string",
          "default": "",
          "description": "Optional system prompt prepended to every conversation."
        },
        "squish.thinkingBudget": {
          "type": "number",
          "default": 0,
          "description": "Qwen3 chain-of-thought budget. 0 = disable. -1 = unlimited. Positive integer caps reasoning tokens."
        },
        "squish.venvPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the squish binary or virtualenv directory. Leave empty to auto-detect."
        },
        "squish.enableInlineCompletion": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline completions triggered by '// squish:' or '# squish:' prefix comments."
        },
        "squish.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show Squish Agent CodeLens actions (Explain | Document | Refactor | Test) above function definitions."
        },
        "squish.agentMaxSteps": {
          "type": "number",
          "default": 10,
          "description": "Maximum number of tool-call iterations before the agent stops."
        },
        "squish.requireApprovalForWrite": {
          "type": "boolean",
          "default": true,
          "description": "Show a confirmation dialog before the agent writes, creates, or deletes files."
        },
        "squish.historyPath": {
          "type": "string",
          "default": "",
          "description": "Directory for persisting conversation history. Defaults to ~/.squish/history."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "jest --testPathPattern=__tests__",
    "package": "npx vsce package --no-dependencies",
    "install:ext": "code --install-extension squish-vscode-0.2.0.vsix --force",
    "deploy": "npm run package && npm run install:ext"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "moduleNameMapper": {
      "^vscode$": "<rootDir>/__mocks__/vscode.ts"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": "<rootDir>/tsconfig.test.json"
      }
    },
    "collectCoverageFrom": ["src/**/*.ts"],
    "coverageThreshold": {
      "global": { "lines": 80 }
    }
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  }
}
